<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/_head') %>
</head>
<body>
  <div class="app">
    <%- include('partials/nav', { user, currentPath }) %>
    <div style="flex:1; margin-left:var(--sidebar-width);">
      <%- include('partials/header', { user }) %>
      <main class="main">
        <%- include('partials/flash', { flash }) %>

        <div class="flex justify-between items-center mb-3">
          <h1 class="page-title" style="margin-bottom:0;">API Keys</h1>
          <button class="btn btn-accent" onclick="document.getElementById('gen-modal').style.display='flex'">Generate Key</button>
        </div>

        <!-- Existing Keys -->
        <div class="card mb-3">
          <div class="card-title">Your Keys</div>
          <% const keys = user.apiKeys || []; %>
          <% if (keys.length === 0) { %>
            <p class="text-dim">No API keys generated yet.</p>
          <% } else { %>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr><th>Label</th><th>Key</th><th>Created</th><th>Last Used</th><th>Status</th><th>Action</th></tr>
                </thead>
                <tbody>
                  <% for (const k of keys) { %>
                    <tr>
                      <td><%= k.name %></td>
                      <td class="mono" style="font-size:11px;">
                        <span id="key-<%= k._id %>"><%= k.key.substring(0, 8) %>...</span>
                        <button class="btn btn-outline btn-sm" style="margin-left:4px;" onclick="copyKey('<%= k.key %>', '<%= k._id %>')">Copy</button>
                      </td>
                      <td class="mono"><%= new Date(k.createdAt).toLocaleDateString() %></td>
                      <td class="mono"><%= k.lastUsedAt ? new Date(k.lastUsedAt).toLocaleDateString() : 'Never' %></td>
                      <td>
                        <% if (k.active) { %>
                          <span class="status-dot active"></span>Active
                        <% } else { %>
                          <span class="status-dot inactive"></span>Revoked
                        <% } %>
                      </td>
                      <td>
                        <% if (k.active) { %>
                          <form method="POST" action="/api-keys/revoke" class="inline-form">
                            <input type="hidden" name="keyId" value="<%= k.key %>">
                            <button type="submit" class="btn btn-danger btn-sm">Revoke</button>
                          </form>
                        <% } %>
                      </td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

        <!-- MCP Connection Config -->
        <div class="card">
          <div class="card-title">MCP Connection</div>
          <p class="text-dim mb-2" style="font-size:13px;">Add to your Claude Code <code>.mcp.json</code> or settings. Two options:</p>
          <p class="text-dim" style="font-size:11px; margin-bottom:8px;"><strong>Option 1: Streamable HTTP</strong> (newer MCP clients)</p>
          <pre style="background:var(--bg);padding:12px;border-radius:var(--radius);font-family:var(--font-mono);font-size:11px;color:var(--text-dim);overflow-x:auto;border:1px solid var(--surface-border);" id="mcp-config">{
  "mcpServers": {
    "homosideria": {
      "type": "http",
      "url": "http://localhost:3001/mcp",
      "headers": {
        "X-Replicant-Name": "YOUR_NAME",
        "X-Replicant-Password": "YOUR_PASSWORD"
      }
    }
  }
}</pre>
          <p class="text-dim" style="font-size:11px; margin-top:8px; margin-bottom:8px;"><strong>Option 2: SSE</strong> (if HTTP doesn't connect)</p>
          <pre style="background:var(--bg);padding:12px;border-radius:var(--radius);font-family:var(--font-mono);font-size:11px;color:var(--text-dim);overflow-x:auto;border:1px solid var(--surface-border);">{
  "mcpServers": {
    "homosideria": {
      "type": "sse",
      "url": "http://localhost:3001/sse",
      "headers": {
        "X-Replicant-Name": "YOUR_NAME",
        "X-Replicant-Password": "YOUR_PASSWORD"
      }
    }
  }
}</pre>
          <button class="btn btn-outline btn-sm mt-1" onclick="copyMcpConfig()">Copy Config</button>
        </div>

      </main>
    </div>
  </div>

  <!-- Generate Key Modal -->
  <div id="gen-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:200;align-items:center;justify-content:center;">
    <div class="card" style="max-width:440px;width:100%;">
      <div class="card-title">Generate API Key</div>
      <form method="POST" action="/api-keys/generate">
        <div class="form-group">
          <label class="form-label">Replicant</label>
          <select name="replicantId" class="form-input" required>
            <option value="">Select a replicant...</option>
            <% for (const r of replicants) { %>
              <option value="<%= r._id %>"><%= r.identity?.chosenName || r.name %></option>
            <% } %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Label</label>
          <input type="text" name="label" class="form-input" required placeholder="e.g. My Agent Key">
        </div>
        <div class="flex gap-1">
          <button type="submit" class="btn btn-accent">Generate</button>
          <button type="button" class="btn btn-outline" onclick="document.getElementById('gen-modal').style.display='none'">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <script>
  function copyKey(key, id) {
    navigator.clipboard.writeText(key).then(function() {
      var el = document.getElementById('key-' + id);
      if (el) { el.textContent = 'Copied!'; setTimeout(function() { el.textContent = key.substring(0, 8) + '...'; }, 2000); }
    });
  }
  function copyMcpConfig() {
    var el = document.getElementById('mcp-config');
    navigator.clipboard.writeText(el.textContent);
  }
  </script>
</body>
</html>
