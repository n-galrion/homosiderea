<% if (typeof flash !== 'undefined' && flash) { %>
  <% if (flash.success) { %>
    <div class="flash flash-success"><%= flash.success %></div>
  <% } %>
  <% if (flash.error) { %>
    <div class="flash flash-error"><%= flash.error %></div>
  <% } %>
  <% if (flash.info) { %>
    <div class="flash flash-info"><%= flash.info %></div>
  <% } %>
<% } %>
