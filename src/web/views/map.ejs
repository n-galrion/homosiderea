<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/_head') %>
  <style>
    #map-canvas {
      width: 100%;
      height: calc(100vh - var(--topbar-height) - 120px);
      min-height: 500px;
      background: #050508;
      border: 1px solid var(--surface-border);
      border-radius: var(--radius);
      cursor: grab;
    }
    #map-canvas:active { cursor: grabbing; }
    .map-controls { display:flex; gap:8px; margin-bottom:12px; align-items:center; }
    .map-controls button { padding:6px 12px; }

    /* Detail panel */
    .map-detail-panel {
      position: fixed;
      top: var(--topbar-height);
      right: 0;
      width: 350px;
      height: calc(100vh - var(--topbar-height));
      background: var(--surface);
      border-left: 1px solid var(--surface-border);
      z-index: 200;
      overflow-y: auto;
      transform: translateX(100%);
      transition: transform 200ms ease;
      padding: 20px;
    }
    .map-detail-panel.open { transform: translateX(0); }
    .map-detail-panel .panel-close {
      position: absolute; top: 12px; right: 12px;
      background: none; border: 1px solid var(--surface-border);
      color: var(--text-dim); font-size: 18px; cursor: pointer;
      width: 28px; height: 28px; display: flex; align-items: center;
      justify-content: center; border-radius: var(--radius);
    }
    .map-detail-panel .panel-close:hover { color: var(--text); border-color: var(--text-muted); }
    .map-detail-panel h2 { font-size: 18px; margin-bottom: 4px; color: var(--accent); }
    .map-detail-panel .body-type-badge {
      display: inline-block; font-size: 10px; text-transform: uppercase;
      letter-spacing: 0.05em; padding: 2px 8px; border-radius: 2px;
      background: var(--surface-raised); border: 1px solid var(--surface-border);
      color: var(--text-dim); margin-bottom: 12px;
    }
    .map-detail-panel .detail-section { margin-bottom: 16px; }
    .map-detail-panel .detail-section h3 {
      font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--text-muted); margin-bottom: 6px;
    }
    .map-detail-panel .detail-row {
      display: flex; justify-content: space-between; padding: 3px 0;
      font-size: 12px; border-bottom: 1px solid rgba(42,42,42,0.4);
    }
    .map-detail-panel .detail-row .label { color: var(--text-dim); }
    .map-detail-panel .detail-row .value { color: var(--text); font-family: var(--font-mono); font-size: 11px; }
    .map-detail-panel .resource-bar-wrap {
      margin-bottom: 6px;
    }
    .map-detail-panel .resource-bar-label {
      font-size: 11px; color: var(--text-dim); margin-bottom: 2px;
      display: flex; justify-content: space-between;
    }
    .map-detail-panel .resource-bar {
      height: 6px; background: var(--surface-raised); border-radius: 3px; overflow: hidden;
    }
    .map-detail-panel .resource-bar-fill {
      height: 100%; background: var(--accent); border-radius: 3px;
    }
    .map-detail-panel .settlement-item {
      padding: 8px; margin-bottom: 6px;
      background: var(--surface-raised); border: 1px solid var(--surface-border);
      border-radius: var(--radius);
    }
    .map-detail-panel .settlement-item .sett-name { font-size: 13px; color: var(--text); }
    .map-detail-panel .settlement-item .sett-meta {
      font-size: 11px; color: var(--text-muted); margin-top: 2px;
    }
    .map-detail-panel .no-data { font-size: 12px; color: var(--text-muted); font-style: italic; }
  </style>
</head>
<body>
  <div class="app">
    <%- include('partials/nav', { user, currentPath }) %>
    <div style="flex:1; margin-left:var(--sidebar-width);">
      <%- include('partials/header', { user }) %>
      <main class="main">
        <%- include('partials/flash', { flash }) %>

        <h1 class="page-title">Sol System Map</h1>

        <div class="map-controls">
          <button class="btn btn-outline btn-sm" id="zoom-in">+ Zoom In</button>
          <button class="btn btn-outline btn-sm" id="zoom-out">- Zoom Out</button>
          <button class="btn btn-outline btn-sm" id="zoom-reset">Reset</button>
          <span class="text-muted mono" style="font-size:11px;margin-left:auto;" id="map-info">Loading...</span>
        </div>

        <canvas id="map-canvas"></canvas>

        <div id="map-detail" class="map-detail-panel">
          <button class="panel-close" id="panel-close" title="Close">&times;</button>
          <h2 id="detail-name"></h2>
          <span class="body-type-badge" id="detail-type"></span>

          <div class="detail-section" id="detail-position-section">
            <h3>Position</h3>
            <div id="detail-position"></div>
          </div>

          <div class="detail-section" id="detail-physical-section" style="display:none;">
            <h3>Physical Properties</h3>
            <div id="detail-physical"></div>
          </div>

          <div class="detail-section" id="detail-resources-section" style="display:none;">
            <h3>Resources</h3>
            <div id="detail-resources"></div>
          </div>

          <div class="detail-section" id="detail-settlements-section" style="display:none;">
            <h3>Settlements</h3>
            <div id="detail-settlements"></div>
          </div>
        </div>

      </main>
    </div>
  </div>

  <script src="/web/js/map.js" type="module"></script>
</body>
</html>
