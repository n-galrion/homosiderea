<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/_head') %>
</head>
<body>
  <div class="auth-page">
    <div class="auth-card">
      <div class="auth-brand">
        <span class="dot"></span>
        HOMOSIDERIA
      </div>
      <div class="auth-tagline">Create Account</div>

      <%- include('partials/flash') %>

      <form method="POST" action="/auth/register">
        <div class="form-group">
          <label class="form-label" for="username">Username</label>
          <input class="form-input" type="text" id="username" name="username" required autocomplete="username" autofocus>
        </div>
        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input class="form-input" type="email" id="email" name="email" required autocomplete="email">
        </div>
        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <input class="form-input" type="password" id="password" name="password" required autocomplete="new-password">
        </div>
        <div class="form-group">
          <label class="form-label" for="confirmPassword">Confirm Password</label>
          <input class="form-input" type="password" id="confirmPassword" name="confirmPassword" required autocomplete="new-password">
        </div>
        <button type="submit" class="btn btn-accent btn-block">Register</button>
      </form>

      <div class="auth-footer">
        Already have an account? <a href="/login">Login</a>
      </div>
    </div>
  </div>
</body>
</html>
